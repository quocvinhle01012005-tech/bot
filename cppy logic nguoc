//+------------------------------------------------------------------+
//|  DCA_Duong_Bot.mq5                                               |
//|  Buy Stop / Sell Stop OCO                                        |
//|  - Khop ben nao -> huy ben con lai                               |
//|  - Gia di thuan chieu 1 gia -> DCA x1.5 + doi SL len 1 gia      |
//|  - SL hit -> dong tat, dat lai tu dau                            |
//|  - Khong co TP tu dong                                           |
//+------------------------------------------------------------------+
#property copyright "DCA Duong Bot"
#property version   "1.00"
#property strict

#include <Trade\Trade.mqh>
CTrade trade;

//================== INPUT ==================
input group "=== Dat lenh dau ==="
input double InpInitialLot   = 0.01;  // Lot ban dau
input double InpDistance     = 1.0;   // Khoang cach BuyStop/SellStop tu gia hien tai (1 gia)

input group "=== DCA ==="
input double InpDCAMult      = 1.5;   // He so nhan lot moi lan DCA (x1.5)

input group "=== Khac ==="
input ulong  InpMagic        = 20240601;
input string InpComment      = "DCA_Duong";
input int    InpSlippage     = 10;

//================== GLOBAL ==================
ulong  gTickBuy      = 0;
ulong  gTickSell     = 0;
bool   gActive       = false;
int    gDir          = 0;       // 1=BUY, -1=SELL
double gNextDCALot   = 0;       // Lot lan DCA tiep theo
double gLastEntryPx  = 0;       // Gia vao lenh gan nhat (de biet khi nao +1 gia)
double gCurrentSL    = 0;       // SL hien tai cua tat ca lenh basket
int    gDCACount     = 0;
int    gDigits;

//+------------------------------------------------------------------+
int OnInit()
{
   gDigits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   trade.SetExpertMagicNumber(InpMagic);
   trade.SetDeviationInPoints(InpSlippage);

   PrintFormat("=== DCA Duong Bot | %s | digits=%d ===", _Symbol, gDigits);
   PrintFormat("Distance=%.2f | DCAx%.1f", InpDistance, InpDCAMult);

   if(!HasAnyEAOrder())
      PlaceInitialPair();

   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason) {}

//+------------------------------------------------------------------+
void OnTick()
{
   if(!gActive)
   {
      CheckPendingFilled();

      if(!gActive && gTickBuy == 0 && gTickSell == 0)
         if(!HasAnyEAOrder())
            PlaceInitialPair();
      return;
   }

   // Kiem tra SL da hit chua (khong con position nao)
   if(!HasPositionByMagic())
   {
      Print(">> SL hit / dong het -> Reset, dat lai tu dau");
      ResetAll();
      PlaceInitialPair();
      return;
   }

   double cur = (gDir == 1) ? SymbolInfoDouble(_Symbol, SYMBOL_BID)
                             : SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   // Gia di thuan chieu them InpDistance tu lan vao gan nhat
   double move = (gDir == 1) ? (cur - gLastEntryPx) / InpDistance
                              : (gLastEntryPx - cur) / InpDistance;

   if(move >= 1.0)
   {
      PrintFormat(">>> +%.2f gia | DCA #%d lot=%.2f | Doi SL",
                  move, gDCACount+1, gNextDCALot);
      DoDCAAndMoveSL(cur);
   }
}

//+------------------------------------------------------------------+
//| Dat cap Buy Stop + Sell Stop ban dau                             |
//+------------------------------------------------------------------+
void PlaceInitialPair()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double mid = NormalizeDouble((ask + bid) / 2.0, gDigits);

   double buyPx  = NormalizeDouble(mid + InpDistance, gDigits);
   double sellPx = NormalizeDouble(mid - InpDistance, gDigits);

   // SL: BuyStop  -> SL = entry - 1 gia
   //     SellStop -> SL = entry + 1 gia
   double buySL  = NormalizeDouble(buyPx  - InpDistance, gDigits);  // = mid
   double sellSL = NormalizeDouble(sellPx + InpDistance, gDigits);  // = mid

   PrintFormat(">> Placing | mid=%.5f", mid);
   PrintFormat("   BuyStop=%.5f  SL=%.5f", buyPx,  buySL);
   PrintFormat("   SellStop=%.5f SL=%.5f", sellPx, sellSL);

   // Dat lenh khong co TP
   trade.BuyStop(InpInitialLot, buyPx, _Symbol, buySL, 0, ORDER_TIME_GTC, 0, InpComment);
   gTickBuy = trade.ResultOrder();

   trade.SellStop(InpInitialLot, sellPx, _Symbol, sellSL, 0, ORDER_TIME_GTC, 0, InpComment);
   gTickSell = trade.ResultOrder();

   if(gTickBuy > 0 && gTickSell > 0)
   {
      gNextDCALot = NormalizeDouble(InpInitialLot * InpDCAMult, 2);
      gDCACount   = 0;
      PrintFormat(">> Both placed! Buy=%d Sell=%d", gTickBuy, gTickSell);
   }
   else
   {
      PrintFormat("ERROR placing! Buy=%d Sell=%d -> retry", gTickBuy, gTickSell);
      if(gTickBuy  > 0) trade.OrderDelete(gTickBuy);
      if(gTickSell > 0) trade.OrderDelete(gTickSell);
      gTickBuy = gTickSell = 0;
   }
}

//+------------------------------------------------------------------+
//| Kiem tra lenh nao khop -> huy lenh con lai                       |
//+------------------------------------------------------------------+
void CheckPendingFilled()
{
   bool buyPos   = PositionSelectByTicket(gTickBuy);
   bool sellPos  = PositionSelectByTicket(gTickSell);
   bool buyPend  = OrderSelect(gTickBuy);
   bool sellPend = OrderSelect(gTickSell);

   if(buyPos && !sellPos)
   {
      Print(">> BuyStop khop! Huy SellStop...");
      if(sellPend) trade.OrderDelete(gTickSell);
      gTickSell = 0;
      ActivateBasket(gTickBuy, 1);
   }
   else if(sellPos && !buyPos)
   {
      Print(">> SellStop khop! Huy BuyStop...");
      if(buyPend) trade.OrderDelete(gTickBuy);
      gTickBuy = 0;
      ActivateBasket(gTickSell, -1);
   }
   else if(!buyPos && !sellPos && !buyPend && !sellPend
           && (gTickBuy > 0 || gTickSell > 0))
   {
      Print(">> Ca 2 lenh mat -> Reset");
      ResetAll();
   }
}

void ActivateBasket(ulong ticket, int dir)
{
   if(!PositionSelectByTicket(ticket)) return;
   gDir         = dir;
   gLastEntryPx = PositionGetDouble(POSITION_PRICE_OPEN);
   gCurrentSL   = PositionGetDouble(POSITION_SL);
   gActive      = true;
   PrintFormat(">> ACTIVE %s | entry=%.5f SL=%.5f",
               dir==1?"BUY":"SELL", gLastEntryPx, gCurrentSL);
}

//+------------------------------------------------------------------+
//| DCA them lenh + doi SL len 1 gia cho tat ca lenh                 |
//+------------------------------------------------------------------+
void DoDCAAndMoveSL(double curPrice)
{
   double entryPrice;
   bool sent = false;

   // Mo lenh DCA cung chieu
   if(gDir == 1)
   {
      entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      sent = trade.Buy(gNextDCALot, _Symbol, entryPrice, 0, 0,
                       InpComment + "_DCA" + IntegerToString(gDCACount+1));
   }
   else
   {
      entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      sent = trade.Sell(gNextDCALot, _Symbol, entryPrice, 0, 0,
                        InpComment + "_DCA" + IntegerToString(gDCACount+1));
   }

   uint rc = trade.ResultRetcode();
   if(!sent || (rc != TRADE_RETCODE_DONE && rc != TRADE_RETCODE_PLACED))
   {
      PrintFormat("ERROR DCA: retcode=%d | %s", rc, trade.ResultRetcodeDescription());
      return;
   }

   gDCACount++;
   gLastEntryPx = entryPrice;
   gNextDCALot  = NormalizeDouble(gNextDCALot * InpDCAMult, 2);

   // Doi SL: tang/giam them 1 gia so voi SL hien tai
   double newSL = (gDir == 1)
                  ? NormalizeDouble(gCurrentSL + InpDistance, gDigits)  // BUY: SL dich len
                  : NormalizeDouble(gCurrentSL - InpDistance, gDigits); // SELL: SL dich xuong

   gCurrentSL = newSL;

   // Cap nhat SL cho tat ca lenh trong basket
   MoveAllSL(newSL);

   PrintFormat(">> DCA#%d OK | entry=%.5f | newSL=%.5f | nextLot=%.2f",
               gDCACount, entryPrice, newSL, gNextDCALot);
}

//+------------------------------------------------------------------+
//| Doi SL cho tat ca lenh basket                                    |
//+------------------------------------------------------------------+
void MoveAllSL(double newSL)
{
   for(int i = PositionsTotal()-1; i >= 0; i--)
   {
      ulong t = PositionGetTicket(i);
      if(!PositionSelectByTicket(t)) continue;
      if((long)PositionGetInteger(POSITION_MAGIC) != (long)InpMagic) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;

      double curTP = PositionGetDouble(POSITION_TP);
      trade.PositionModify(t, newSL, curTP);
   }
}

//+------------------------------------------------------------------+
// Helpers
//+------------------------------------------------------------------+
bool HasPositionByMagic()
{
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong t = PositionGetTicket(i);
      if(PositionSelectByTicket(t))
         if((long)PositionGetInteger(POSITION_MAGIC) == (long)InpMagic &&
            PositionGetString(POSITION_SYMBOL) == _Symbol)
            return true;
   }
   return false;
}

bool HasAnyEAOrder()
{
   for(int i = OrdersTotal()-1; i >= 0; i--)
   {
      ulong t = OrderGetTicket(i);
      if(OrderSelect(t))
         if(OrderGetString(ORDER_SYMBOL) == _Symbol &&
            OrderGetInteger(ORDER_MAGIC) == (long)InpMagic)
            return true;
   }
   return HasPositionByMagic();
}

void ResetAll()
{
   gActive      = false;
   gDir         = 0;
   gTickBuy     = 0;
   gTickSell    = 0;
   gNextDCALot  = 0;
   gLastEntryPx = 0;
   gCurrentSL   = 0;
   gDCACount    = 0;
   Print("=== RESET DONE ===");
}
//+------------------------------------------------------------------+
