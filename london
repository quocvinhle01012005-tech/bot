//+------------------------------------------------------------------+
//|              Gold London Breakout EA v2                          |
//|                  XAUUSD - No DCA                                 |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>

CTrade trade;

//=========================
// INPUT
//=========================

input int MagicNumber = 888001;

input double LotSize = 0.01;

input double StopLossUSD = 8.0;
input double TakeProfitUSD = 16.0;

input int AsiaStartHour = 6;
input int AsiaEndHour = 13;

input int TradeStartHour = 14;
input int TradeEndHour = 18;

input double MinRange = 5.0;
input double MaxRange = 18.0;

input int EMAFast = 20;
input int EMASlow = 50;

input int RSIPeriod = 14;

input bool OneTradePerDay = true;

//=========================

double AsiaHigh = 0;
double AsiaLow = 0;

bool TradedToday = false;
int LastDay = -1;

//+------------------------------------------------------------------+
//| INIT                                                             |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(MagicNumber);

   Print("Gold London Breakout EA v2 Started");

   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| MAIN                                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   MqlDateTime tm;
   TimeToStruct(TimeCurrent(), tm);

   int hour = tm.hour;
   int today = tm.day;

   // Reset mỗi ngày
   if(today != LastDay)
   {
      TradedToday = false;
      LastDay = today;
   }

   // Chỉ trade trong giờ London
   if(hour < TradeStartHour || hour > TradeEndHour)
      return;

   // Chỉ 1 lệnh/ngày
   if(OneTradePerDay && TradedToday)
      return;

   // Chỉ check lệnh của chính bot này
   if(HasMyPosition())
      return;

   // Lấy range phiên Á
   GetAsiaRange();

   double range = AsiaHigh - AsiaLow;

   Print("Asia High: ", AsiaHigh);
   Print("Asia Low: ", AsiaLow);
   Print("Range: ", range);

   // Filter range
   if(range < MinRange || range > MaxRange)
   {
      Print("Range không hợp lệ.");
      return;
   }

   // Giá hiện tại
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   // EMA
   double emaFast = GetEMA(EMAFast);
   double emaSlow = GetEMA(EMASlow);

   // RSI
   double rsi = GetRSI(RSIPeriod);

   // Nến M5 đã đóng
   double lastClose = iClose(_Symbol, PERIOD_M5, 1);

   //=========================
   // BUY BREAKOUT
   //=========================

   if(lastClose > AsiaHigh)
   {
      Print("Phát hiện BUY breakout");

      if(emaFast > emaSlow && rsi > 55)
      {
         double sl = ask - StopLossUSD;
         double tp = ask + TakeProfitUSD;

         bool result = trade.Buy(
            LotSize,
            _Symbol,
            ask,
            sl,
            tp,
            "London Breakout BUY"
         );

         if(result)
         {
            Print("BUY OPENED");
            TradedToday = true;
         }
         else
         {
            Print("BUY FAILED");
         }
      }
      else
      {
         Print("BUY bị filter EMA/RSI");
      }
   }

   //=========================
   // SELL BREAKOUT
   //=========================

   if(lastClose < AsiaLow)
   {
      Print("Phát hiện SELL breakout");

      if(emaFast < emaSlow && rsi < 45)
      {
         double sl = bid + StopLossUSD;
         double tp = bid - TakeProfitUSD;

         bool result = trade.Sell(
            LotSize,
            _Symbol,
            bid,
            sl,
            tp,
            "London Breakout SELL"
         );

         if(result)
         {
            Print("SELL OPENED");
            TradedToday = true;
         }
         else
         {
            Print("SELL FAILED");
         }
      }
      else
      {
         Print("SELL bị filter EMA/RSI");
      }
   }
}

//+------------------------------------------------------------------+
//| CHECK POSITION                                                   |
//+------------------------------------------------------------------+
bool HasMyPosition()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);

      if(PositionSelectByTicket(ticket))
      {
         long magic = PositionGetInteger(POSITION_MAGIC);
         string symbol = PositionGetString(POSITION_SYMBOL);

         if(magic == MagicNumber && symbol == _Symbol)
         {
            return true;
         }
      }
   }

   return false;
}

//+------------------------------------------------------------------+
//| GET ASIA RANGE                                                   |
//+------------------------------------------------------------------+
void GetAsiaRange()
{
   AsiaHigh = -999999;
   AsiaLow = 999999;

   for(int i = 0; i < 200; i++)
   {
      datetime candleTime = iTime(_Symbol, PERIOD_M5, i);

      MqlDateTime tm;
      TimeToStruct(candleTime, tm);

      if(tm.hour >= AsiaStartHour && tm.hour <= AsiaEndHour)
      {
         double high = iHigh(_Symbol, PERIOD_M5, i);
         double low = iLow(_Symbol, PERIOD_M5, i);

         if(high > AsiaHigh)
            AsiaHigh = high;

         if(low < AsiaLow)
            AsiaLow = low;
      }
   }
}

//+------------------------------------------------------------------+
//| EMA                                                              |
//+------------------------------------------------------------------+
double GetEMA(int period)
{
   int handle = iMA(
      _Symbol,
      PERIOD_M15,
      period,
      0,
      MODE_EMA,
      PRICE_CLOSE
   );

   double buffer[];

   CopyBuffer(handle, 0, 0, 1, buffer);

   return buffer[0];
}

//+------------------------------------------------------------------+
//| RSI                                                              |
//+------------------------------------------------------------------+
double GetRSI(int period)
{
   int handle = iRSI(
      _Symbol,
      PERIOD_M15,
      period,
      PRICE_CLOSE
   );

   double buffer[];

   CopyBuffer(handle, 0, 0, 1, buffer);

   return buffer[0];
}
