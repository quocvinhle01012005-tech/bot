//+------------------------------------------------------------------+
//|                 Gold London Breakout EA                         |
//|                     XAUUSD - No DCA                             |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>

CTrade trade;

// ======================
// INPUT
// ======================

input double LotSize = 0.01;

input double StopLossUSD = 8.0;
input double TakeProfitUSD = 16.0;

input int AsiaStartHour = 6;
input int AsiaEndHour = 13;

input int TradeStartHour = 14;
input int TradeEndHour = 18;

input double MinRange = 5.0;
input double MaxRange = 18.0;

input int EMAFast = 20;
input int EMASlow = 50;

input int RSIPeriod = 14;

input bool OneTradePerDay = true;

// ======================

double AsiaHigh = 0;
double AsiaLow = 0;

bool TradedToday = false;
int LastDay = -1;

//+------------------------------------------------------------------+
//| Expert initialization                                            |
//+------------------------------------------------------------------+
int OnInit()
{
   Print("Gold London Breakout EA Started");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert tick                                                      |
//+------------------------------------------------------------------+
void OnTick()
{
   datetime now = TimeCurrent();

   MqlDateTime tm;
   TimeToStruct(now, tm);

   int hour = tm.hour;
   int today = tm.day;

   // Reset mỗi ngày
   if(today != LastDay)
   {
      TradedToday = false;
      LastDay = today;
   }

   // Chỉ trade trong giờ
   if(hour < TradeStartHour || hour > TradeEndHour)
      return;

   if(OneTradePerDay && TradedToday)
      return;

   // Không vào thêm nếu đang có lệnh
   if(PositionsTotal() > 0)
      return;

   // Lấy range phiên Á
   GetAsiaRange();

   double range = AsiaHigh - AsiaLow;

   if(range < MinRange || range > MaxRange)
      return;

   // Giá hiện tại
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   // EMA
   double emaFast = GetEMA(EMAFast);
   double emaSlow = GetEMA(EMASlow);

   // RSI
   double rsi = GetRSI(RSIPeriod);

   // ======================
   // BUY BREAKOUT
   // ======================

   double lastClose = iClose(_Symbol, PERIOD_M5, 1);

   if(lastClose > AsiaHigh)
   {
      if(emaFast > emaSlow && rsi > 55)
      {
         double sl = ask - StopLossUSD;
         double tp = ask + TakeProfitUSD;

         trade.Buy(LotSize, _Symbol, ask, sl, tp, "London Breakout BUY");

         Print("BUY OPENED");

         TradedToday = true;
      }
   }

   // ======================
   // SELL BREAKOUT
   // ======================

   if(lastClose < AsiaLow)
   {
      if(emaFast < emaSlow && rsi < 45)
      {
         double sl = bid + StopLossUSD;
         double tp = bid - TakeProfitUSD;

         trade.Sell(LotSize, _Symbol, bid, sl, tp, "London Breakout SELL");

         Print("SELL OPENED");

         TradedToday = true;
      }
   }
}

//+------------------------------------------------------------------+
//| Get Asia Range                                                   |
//+------------------------------------------------------------------+
void GetAsiaRange()
{
   AsiaHigh = -999999;
   AsiaLow = 999999;

   datetime now = TimeCurrent();

   for(int i = 0; i < 200; i++)
   {
      datetime candleTime = iTime(_Symbol, PERIOD_M5, i);

      MqlDateTime tm;
      TimeToStruct(candleTime, tm);

      if(tm.hour >= AsiaStartHour && tm.hour <= AsiaEndHour)
      {
         double high = iHigh(_Symbol, PERIOD_M5, i);
         double low = iLow(_Symbol, PERIOD_M5, i);

         if(high > AsiaHigh)
            AsiaHigh = high;

         if(low < AsiaLow)
            AsiaLow = low;
      }
   }
}

//+------------------------------------------------------------------+
//| EMA                                                              |
//+------------------------------------------------------------------+
double GetEMA(int period)
{
   int handle = iMA(_Symbol, PERIOD_M15, period, 0, MODE_EMA, PRICE_CLOSE);

   double buffer[];

   CopyBuffer(handle, 0, 0, 1, buffer);

   return buffer[0];
}

//+------------------------------------------------------------------+
//| RSI                                                              |
//+------------------------------------------------------------------+
double GetRSI(int period)
{
   int handle = iRSI(_Symbol, PERIOD_M15, period, PRICE_CLOSE);

   double buffer[];

   CopyBuffer(handle, 0, 0, 1, buffer);

   return buffer[0];
}
