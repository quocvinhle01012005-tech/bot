//+------------------------------------------------------------------+
//| EMA + DCA BOT + UI BUTTONS                                       |
//| Chot loi theo tong lot / Lot x TP                                |
//| Hedge can bang: dung DCA, cho lenh thao rao theo gia vs moc      |
//+------------------------------------------------------------------+
#include <Trade/Trade.mqh>
CTrade trade;

input double Lot              = 0.01;
input int    MaxOrders        = 20;
input double DCA_Distance     = 5.0;
input int    EMA_Fast         = 50;
input int    EMA_Slow         = 200;
input int    MagicNumber      = 123456;

input group "=== CHOT LOI THEO LOT ==="
input int    DCA_Threshold       = 10;   // Nguong so lenh doi he so
input double TP_Multiplier_Low   = 7.0;   // $ chot loi moi 0.01 lot khi <= nguong
input double TP_Multiplier_High  = 15.0;  // $ chot loi moi 0.01 lot khi > nguong

input group "=== HEDGE CAN BANG ==="
input double Hedge_Drawdown  = 0.0;   // % DD kich hoat hedge (0 = tat)
// Hang rao: tu tinh = chenh lech x 0.01 | Thao rao: co dinh 0.01

input group "=== CHART BUTTONS ==="
input bool   ButtonCornerTop = true;
input int    ButtonOffsetX   = 12;
input int    ButtonOffsetY   = 28;
input int    ButtonWidth     = 150;
input int    ButtonHeight    = 28;
input int    ButtonGap       = 4;

int    g_total_orders      = 0;
bool   g_buy_opened        = false;
bool   g_sell_opened       = false;
bool   g_hedge_active      = false;
double g_hedge_price       = 0;
long   g_hedge_type        = -1;
bool   g_thao_rao_opened   = false;  // Da mo lenh thao rao chua

const string BTN_BUY        = "EMA_BtnBuy";
const string BTN_CLOSE_BUY  = "EMA_BtnCloseBuy";
const string BTN_SELL       = "EMA_BtnSell";
const string BTN_CLOSE_SELL = "EMA_BtnCloseSell";
const string BTN_CLOSE_ALL  = "EMA_BtnCloseAll";
const string LBL_STATS      = "EMA_LblStats";

//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(MagicNumber);
   g_total_orders    = 0;
   g_buy_opened      = false;
   g_sell_opened     = false;
   g_hedge_active    = false;
   g_hedge_price     = 0;
   g_hedge_type      = -1;
   g_thao_rao_opened = false;
   CreateButtons();
   CreateStatsLabel();
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   ObjectDelete(0, BTN_BUY);
   ObjectDelete(0, BTN_CLOSE_BUY);
   ObjectDelete(0, BTN_SELL);
   ObjectDelete(0, BTN_CLOSE_SELL);
   ObjectDelete(0, BTN_CLOSE_ALL);
   ObjectDelete(0, LBL_STATS);
}

//+------------------------------------------------------------------+
bool IsPriceZoneClear(double new_price, long pos_type)
{
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetInteger(POSITION_TYPE)  != pos_type) continue;
      double op = PositionGetDouble(POSITION_PRICE_OPEN);
      if(MathAbs(new_price - op) < DCA_Distance) return false;
   }
   return true;
}

double ProfitByType(long pos_type)
{
   double profit = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetInteger(POSITION_TYPE)  != pos_type) continue;
      profit += PositionGetDouble(POSITION_PROFIT);
      profit += PositionGetDouble(POSITION_SWAP);
   }
   return profit;
}

// Tinh tong lot theo chieu
double TotalLotByType(long pos_type)
{
   double total_lot = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetInteger(POSITION_TYPE)  != pos_type) continue;
      total_lot += PositionGetDouble(POSITION_VOLUME);
   }
   return total_lot;
}

//+------------------------------------------------------------------+
void OnTick()
{
   double balance  = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity   = AccountInfoDouble(ACCOUNT_EQUITY);
   double bid      = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask      = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double price    = (bid + ask) / 2.0;
   double emaFast  = GetEMA(EMA_Fast);
   double emaSlow  = GetEMA(EMA_Slow);
   int    buys     = CountByType(POSITION_TYPE_BUY);
   int    sells    = CountByType(POSITION_TYPE_SELL);
   double drawdown = (balance > 0) ? (balance - equity) / balance * 100.0 : 0;

   if(buys  == 0) g_buy_opened  = false;
   if(sells == 0) g_sell_opened = false;
   if(buys  == 0 && sells == 0)
   {
      g_hedge_active    = false;
      g_hedge_price     = 0;
      g_hedge_type      = -1;
      g_thao_rao_opened = false;
   }

   // --- KICH HOAT HEDGE (1 lan, khong lap lai) ---
   if(Hedge_Drawdown > 0 && !g_hedge_active && drawdown >= Hedge_Drawdown)
   {
      int diff = buys - sells;

      if(diff > 0)
      {
         // BUY nhieu hon: mo 1 lenh SELL hang rao
         double hedge_lot = NormalizeDouble(diff * Lot, 2);
         Print("EMA HEDGE: Mo SELL hang rao lot=", hedge_lot,
               " (chenh=", diff, " x ", Lot, ") Buy=", buys, " Sell=", sells);
         trade.Sell(hedge_lot);
         g_hedge_price = bid;
         g_hedge_type  = POSITION_TYPE_SELL;
         g_sell_opened = true;
      }
      else if(diff < 0)
      {
         int add = MathAbs(diff);
         double hedge_lot = NormalizeDouble(add * Lot, 2);
         Print("EMA HEDGE: Mo BUY hang rao lot=", hedge_lot,
               " (chenh=", add, " x ", Lot, ") Buy=", buys, " Sell=", sells);
         trade.Buy(hedge_lot);
         g_hedge_price = ask;
         g_hedge_type  = POSITION_TYPE_BUY;
         g_buy_opened  = true;
      }
      else
      {
         Print("EMA HEDGE: Da can bang san (Buy=Sell=", buys, ")");
         g_hedge_price = price;
         g_hedge_type  = -1;
      }

      g_hedge_active    = true;
      g_thao_rao_opened = false;
      RefreshUI();
      return;  // Dung lai, tick sau xu ly tiep
   }

   // --- DANG HEDGE: dung DCA, tat chot loi $, mo lenh thao rao ---
   if(g_hedge_active && g_hedge_price > 0)
   {
      buys  = CountByType(POSITION_TYPE_BUY);
      sells = CountByType(POSITION_TYPE_SELL);

      // Kiem tra tin hieu thao rao (gia vs moc + EMA dung chieu)
      bool signal_close_buy  = (price > g_hedge_price && emaFast < emaSlow && buys  > 0);
      bool signal_close_sell = (price < g_hedge_price && emaFast > emaSlow && sells > 0);

      // Mo lenh thao rao neu chua mo (chi de lam dau hieu, khong bat buoc thanh cong)
      if(!g_thao_rao_opened)
      {
         if(signal_close_buy)
         {
            Print("EMA THAO RAO: Gia tang, mo SELL lot=", Lot);
            trade.Sell(Lot);
            g_thao_rao_opened = true;
            g_sell_opened     = true;
         }
         else if(signal_close_sell)
         {
            Print("EMA THAO RAO: Gia giam, mo BUY lot=", Lot);
            trade.Buy(Lot);
            g_thao_rao_opened = true;
            g_buy_opened      = true;
         }
      }

      // Dong chieu lo ngay khi co tin hieu, khong phu thuoc lenh thao rao mo thanh cong
      buys  = CountByType(POSITION_TYPE_BUY);
      sells = CountByType(POSITION_TYPE_SELL);

      if(signal_close_buy && buys > 0)
      {
         // Gia tang + tin hieu SELL: dong het BUY, giu SELL
         Print("EMA THAO RAO: Dong het BUY (", buys, " lenh)");
         CloseByType(POSITION_TYPE_BUY);
         g_buy_opened      = false;
         g_hedge_active    = false;
         g_hedge_price     = 0;
         g_hedge_type      = -1;
         g_thao_rao_opened = false;
      }
      else if(signal_close_sell && sells > 0)
      {
         // Gia giam + tin hieu BUY: dong het SELL, giu BUY
         Print("EMA THAO RAO: Dong het SELL (", sells, " lenh)");
         CloseByType(POSITION_TYPE_SELL);
         g_sell_opened     = false;
         g_hedge_active    = false;
         g_hedge_price     = 0;
         g_hedge_type      = -1;
         g_thao_rao_opened = false;
      }

      RefreshUI();
      return;  // Dang hedge: khong DCA, khong chot loi $
   }

   // --- CHOT LOI THEO LOT (chi khi khong hedge) ---
   // Cong thuc: tong_lot / Lot x TP_Multiplier = target $
   buys  = CountByType(POSITION_TYPE_BUY);
   sells = CountByType(POSITION_TYPE_SELL);

   if(buys > 0)
   {
      double buy_lot    = TotalLotByType(POSITION_TYPE_BUY);
      double buy_units  = NormalizeDouble(buy_lot / Lot, 0);
      double buy_multi  = (buy_units <= DCA_Threshold) ? TP_Multiplier_Low : TP_Multiplier_High;
      double buy_target = buy_units * buy_multi;
      double buy_profit = ProfitByType(POSITION_TYPE_BUY);
      if(buy_profit >= buy_target)
      {
         Print("EMA: Chot loi BUY $", DoubleToString(buy_profit,2),
               " (lot=", buy_lot, " -> ", buy_units, " don vi x $", buy_multi,
               " = $", DoubleToString(buy_target,2), ")");
         CloseByType(POSITION_TYPE_BUY);
         g_buy_opened = false;
      }
   }

   if(sells > 0)
   {
      double sell_lot    = TotalLotByType(POSITION_TYPE_SELL);
      double sell_units  = NormalizeDouble(sell_lot / Lot, 0);
      double sell_multi  = (sell_units <= DCA_Threshold) ? TP_Multiplier_Low : TP_Multiplier_High;
      double sell_target = sell_units * sell_multi;
      double sell_profit = ProfitByType(POSITION_TYPE_SELL);
      if(sell_profit >= sell_target)
      {
         Print("EMA: Chot loi SELL $", DoubleToString(sell_profit,2),
               " (lot=", sell_lot, " -> ", sell_units, " don vi x $", sell_multi,
               " = $", DoubleToString(sell_target,2), ")");
         CloseByType(POSITION_TYPE_SELL);
         g_sell_opened = false;
      }
   }

   buys  = CountByType(POSITION_TYPE_BUY);
   sells = CountByType(POSITION_TYPE_SELL);

   // ===== XU LY BUY DOC LAP =====
   if(emaFast > emaSlow)
   {
      if(!g_buy_opened)
      {
         trade.Buy(Lot);
         g_buy_opened = true;
         g_total_orders++;
         Print("EMA: Mo BUY dau tien @ ", ask);
      }
      else if(buys > 0 && buys < MaxOrders)
      {
         double lowest_buy = 999999;
         for(int i = 0; i < PositionsTotal(); i++)
         {
            ulong ticket = PositionGetTicket(i);
            if(ticket == 0) continue;
            if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
            if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
            if(PositionGetInteger(POSITION_TYPE)  != POSITION_TYPE_BUY) continue;
            double op = PositionGetDouble(POSITION_PRICE_OPEN);
            if(op < lowest_buy) lowest_buy = op;
         }
         if(bid < lowest_buy - DCA_Distance && IsPriceZoneClear(ask, POSITION_TYPE_BUY))
         {
            trade.Buy(Lot);
            g_total_orders++;
            Print("EMA: DCA BUY @ ", ask);
         }
      }
   }

   // ===== XU LY SELL DOC LAP =====
   if(emaFast < emaSlow)
   {
      if(!g_sell_opened)
      {
         trade.Sell(Lot);
         g_sell_opened = true;
         g_total_orders++;
         Print("EMA: Mo SELL dau tien @ ", bid);
      }
      else if(sells > 0 && sells < MaxOrders)
      {
         double highest_sell = 0;
         for(int i = 0; i < PositionsTotal(); i++)
         {
            ulong ticket = PositionGetTicket(i);
            if(ticket == 0) continue;
            if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
            if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
            if(PositionGetInteger(POSITION_TYPE)  != POSITION_TYPE_SELL) continue;
            double op = PositionGetDouble(POSITION_PRICE_OPEN);
            if(op > highest_sell) highest_sell = op;
         }
         if(ask > highest_sell + DCA_Distance && IsPriceZoneClear(bid, POSITION_TYPE_SELL))
         {
            trade.Sell(Lot);
            g_total_orders++;
            Print("EMA: DCA SELL @ ", bid);
         }
      }
   }

   RefreshUI();
}

//+------------------------------------------------------------------+
void OnChartEvent(const int id, const long &lparam,
                  const double &dparam, const string &sparam)
{
   if(id != CHARTEVENT_OBJECT_CLICK) return;

   if(sparam == BTN_BUY)
   {
      ObjectSetInteger(0, BTN_BUY, OBJPROP_STATE, false);
      trade.Buy(Lot);
      g_buy_opened = true;
      g_total_orders++;
   }
   else if(sparam == BTN_SELL)
   {
      ObjectSetInteger(0, BTN_SELL, OBJPROP_STATE, false);
      trade.Sell(Lot);
      g_sell_opened = true;
      g_total_orders++;
   }
   else if(sparam == BTN_CLOSE_BUY)
   {
      ObjectSetInteger(0, BTN_CLOSE_BUY, OBJPROP_STATE, false);
      CloseByType(POSITION_TYPE_BUY);
      g_buy_opened = false;
   }
   else if(sparam == BTN_CLOSE_SELL)
   {
      ObjectSetInteger(0, BTN_CLOSE_SELL, OBJPROP_STATE, false);
      CloseByType(POSITION_TYPE_SELL);
      g_sell_opened = false;
   }
   else if(sparam == BTN_CLOSE_ALL)
   {
      ObjectSetInteger(0, BTN_CLOSE_ALL, OBJPROP_STATE, false);
      CloseAll();
      g_total_orders    = 0;
      g_buy_opened      = false;
      g_sell_opened     = false;
      g_hedge_active    = false;
      g_hedge_price     = 0;
      g_hedge_type      = -1;
      g_thao_rao_opened = false;
   }

   RefreshUI();
}

//+------------------------------------------------------------------+
double GetEMA(int period)
{
   int handle = iMA(_Symbol, PERIOD_CURRENT, period, 0, MODE_EMA, PRICE_CLOSE);
   if(handle == INVALID_HANDLE) return 0;
   double buf[1];
   if(CopyBuffer(handle, 0, 0, 1, buf) <= 0) return 0;
   return buf[0];
}

int CountOrders()
{
   int total = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      total++;
   }
   return total;
}

int CountByType(long pos_type)
{
   int total = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetInteger(POSITION_TYPE)  != pos_type) continue;
      total++;
   }
   return total;
}

double TotalProfit()
{
   double profit = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      profit += PositionGetDouble(POSITION_PROFIT);
      profit += PositionGetDouble(POSITION_SWAP);
   }
   return profit;
}

void CloseAll()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      trade.PositionClose(ticket);
   }
}

void CloseByType(long pos_type)
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetInteger(POSITION_TYPE)  != pos_type) continue;
      trade.PositionClose(ticket);
   }
}

void CreateButtons()
{
   ENUM_BASE_CORNER corner = ButtonCornerTop ? CORNER_LEFT_UPPER : CORNER_LEFT_LOWER;
   int x = ButtonOffsetX;
   int y = ButtonOffsetY;
   int h = ButtonHeight + ButtonGap;
   MakeButton(BTN_BUY,        "BUY",        x, y, clrGreen,     corner); y += h;
   MakeButton(BTN_CLOSE_BUY,  "Close BUY",  x, y, clrDimGray,   corner); y += h;
   MakeButton(BTN_SELL,       "SELL",        x, y, clrFireBrick, corner); y += h;
   MakeButton(BTN_CLOSE_SELL, "Close SELL", x, y, clrDimGray,   corner); y += h;
   MakeButton(BTN_CLOSE_ALL,  "Close ALL",  x, y, clrDimGray,   corner);
}

void MakeButton(const string name, const string text,
                const int xd, const int yd, const color bg,
                const ENUM_BASE_CORNER corner)
{
   if(ObjectFind(0, name) >= 0) { ObjectSetString(0, name, OBJPROP_TEXT, text); return; }
   if(!ObjectCreate(0, name, OBJ_BUTTON, 0, 0, 0)) return;
   ObjectSetInteger(0, name, OBJPROP_CORNER,       corner);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE,    xd);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE,    yd);
   ObjectSetInteger(0, name, OBJPROP_XSIZE,        ButtonWidth);
   ObjectSetInteger(0, name, OBJPROP_YSIZE,        ButtonHeight);
   ObjectSetString(0,  name, OBJPROP_TEXT,         text);
   ObjectSetInteger(0, name, OBJPROP_COLOR,        clrWhite);
   ObjectSetInteger(0, name, OBJPROP_BGCOLOR,      bg);
   ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, clrSilver);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE,   false);
}

void CreateStatsLabel()
{
   if(ObjectFind(0, LBL_STATS) >= 0) return;
   ENUM_BASE_CORNER corner = ButtonCornerTop ? CORNER_LEFT_UPPER : CORNER_LEFT_LOWER;
   int x = ButtonOffsetX;
   int y = ButtonOffsetY + (ButtonHeight + ButtonGap) * 5 + 6;
   ObjectCreate(0, LBL_STATS, OBJ_LABEL, 0, 0, 0);
   ObjectSetInteger(0, LBL_STATS, OBJPROP_CORNER,     corner);
   ObjectSetInteger(0, LBL_STATS, OBJPROP_XDISTANCE,  x);
   ObjectSetInteger(0, LBL_STATS, OBJPROP_YDISTANCE,  y);
   ObjectSetInteger(0, LBL_STATS, OBJPROP_COLOR,      clrYellow);
   ObjectSetInteger(0, LBL_STATS, OBJPROP_FONTSIZE,   9);
   ObjectSetString(0,  LBL_STATS, OBJPROP_FONT,       "Arial Bold");
   ObjectSetInteger(0, LBL_STATS, OBJPROP_SELECTABLE, false);
   ObjectSetString(0,  LBL_STATS, OBJPROP_TEXT,       "BUY P&L: $0.00  |  SELL P&L: $0.00");
}

void RefreshUI()
{
   int    buy_count  = CountByType(POSITION_TYPE_BUY);
   int    sell_count = CountByType(POSITION_TYPE_SELL);
   double buy_pnl    = ProfitByType(POSITION_TYPE_BUY);
   double sell_pnl   = ProfitByType(POSITION_TYPE_SELL);

   color buy_bg = (buy_count > 0) ? clrDarkGreen : clrGreen;
   if(ObjectFind(0, BTN_BUY) >= 0)
   {
      ObjectSetInteger(0, BTN_BUY, OBJPROP_BGCOLOR, buy_bg);
      string lbl = (buy_count > 0) ? ("BUY " + IntegerToString(buy_count)) : "BUY";
      ObjectSetString(0, BTN_BUY, OBJPROP_TEXT, lbl);
   }

   color sell_bg = (sell_count > 0) ? clrMaroon : clrFireBrick;
   if(ObjectFind(0, BTN_SELL) >= 0)
   {
      ObjectSetInteger(0, BTN_SELL, OBJPROP_BGCOLOR, sell_bg);
      string lbl = (sell_count > 0) ? ("SELL " + IntegerToString(sell_count)) : "SELL";
      ObjectSetString(0, BTN_SELL, OBJPROP_TEXT, lbl);
   }

   if(ObjectFind(0, LBL_STATS) < 0) CreateStatsLabel();
   string buy_pnl_str  = (buy_pnl  >= 0 ? "+" : "") + DoubleToString(buy_pnl,  2);
   string sell_pnl_str = (sell_pnl >= 0 ? "+" : "") + DoubleToString(sell_pnl, 2);
   string hedge_status = g_hedge_active ? (g_thao_rao_opened ? "  [THAO RAO]" : "  [HEDGE ON]") : "";
   string txt = "BUY P&L: $" + buy_pnl_str + "  |  SELL P&L: $" + sell_pnl_str + hedge_status;
   ObjectSetString(0, LBL_STATS, OBJPROP_TEXT, txt);

   double pnl_total = buy_pnl + sell_pnl;
   color c = g_hedge_active ? clrOrange : ((pnl_total > 0) ? clrLime : (pnl_total < 0 ? clrRed : clrYellow));
   ObjectSetInteger(0, LBL_STATS, OBJPROP_COLOR, c);

   ChartRedraw();
}
