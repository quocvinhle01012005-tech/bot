//+------------------------------------------------------------------+
//|                Gold Sweep Reversal EA                            |
//|                Liquidity Sweep + BOS                             |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>
CTrade trade;

input double LotSize = 0.01;
input double RR = 2.0;

input int TradeStartHour = 14;
input int TradeEndHour = 23;

input int SwingLookback = 20;
input double SweepBuffer = 0.5;
input double BOSBuffer = 0.3;
input double SLBuffer = 1.0;

input int MaxTradesPerDay = 2;

bool WaitingBOS = false;
string BOSDirection = "";

double SweepHigh = 0;
double SweepLow = 0;
double BOSLevel = 0;

int TradeCountToday = 0;
int LastDay = -1;

//+------------------------------------------------------------------+
int OnInit()
{
   Print("Gold Sweep Reversal EA Started");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
void OnTick()
{
   MqlDateTime tm;
   TimeToStruct(TimeCurrent(), tm);

   if(tm.day != LastDay)
   {
      TradeCountToday = 0;
      LastDay = tm.day;
      WaitingBOS = false;
   }

   if(tm.hour < TradeStartHour || tm.hour > TradeEndHour)
      return;

   if(TradeCountToday >= MaxTradesPerDay)
      return;

   if(PositionsTotal() > 0)
      return;

   double lastClose = iClose(_Symbol, PERIOD_M5, 1);
   double lastHigh  = iHigh(_Symbol, PERIOD_M5, 1);
   double lastLow   = iLow(_Symbol, PERIOD_M5, 1);

   double prevHigh  = iHigh(_Symbol, PERIOD_M5, 2);
   double prevLow   = iLow(_Symbol, PERIOD_M5, 2);

   if(!WaitingBOS)
   {
      double swingHigh = GetSwingHigh();
      double swingLow  = GetSwingLow();

      // SELL sweep: quét đỉnh rồi đóng xuống lại
      if(lastHigh > swingHigh + SweepBuffer && lastClose < swingHigh)
      {
         WaitingBOS = true;
         BOSDirection = "SELL";
         SweepHigh = lastHigh;
         SweepLow = lastLow;
         BOSLevel = prevLow;

         Print("Phát hiện sweep đỉnh, chờ BOS SELL");
         return;
      }

      // BUY sweep: quét đáy rồi đóng lên lại
      if(lastLow < swingLow - SweepBuffer && lastClose > swingLow)
      {
         WaitingBOS = true;
         BOSDirection = "BUY";
         SweepHigh = lastHigh;
         SweepLow = lastLow;
         BOSLevel = prevHigh;

         Print("Phát hiện sweep đáy, chờ BOS BUY");
         return;
      }
   }
   else
   {
      if(BOSDirection == "SELL")
      {
         if(lastClose < BOSLevel - BOSBuffer)
         {
            OpenSell();
            WaitingBOS = false;
         }
      }

      if(BOSDirection == "BUY")
      {
         if(lastClose > BOSLevel + BOSBuffer)
         {
            OpenBuy();
            WaitingBOS = false;
         }
      }
   }
}

//+------------------------------------------------------------------+
double GetSwingHigh()
{
   double high = -999999;

   for(int i = 3; i < SwingLookback + 3; i++)
   {
      double h = iHigh(_Symbol, PERIOD_M5, i);
      if(h > high)
         high = h;
   }

   return high;
}

//+------------------------------------------------------------------+
double GetSwingLow()
{
   double low = 999999;

   for(int i = 3; i < SwingLookback + 3; i++)
   {
      double l = iLow(_Symbol, PERIOD_M5, i);
      if(l < low)
         low = l;
   }

   return low;
}

//+------------------------------------------------------------------+
void OpenSell()
{
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   double sl = SweepHigh + SLBuffer;
   double risk = sl - bid;
   double tp = bid - risk * RR;

   if(risk <= 0)
      return;

   trade.Sell(LotSize, _Symbol, bid, sl, tp, "Sweep BOS SELL");

   TradeCountToday++;

   Print("SELL opened | SL=", sl, " TP=", tp);
}

//+------------------------------------------------------------------+
void OpenBuy()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   double sl = SweepLow - SLBuffer;
   double risk = ask - sl;
   double tp = ask + risk * RR;

   if(risk <= 0)
      return;

   trade.Buy(LotSize, _Symbol, ask, sl, tp, "Sweep BOS BUY");

   TradeCountToday++;

   Print("BUY opened | SL=", sl, " TP=", tp);
}
