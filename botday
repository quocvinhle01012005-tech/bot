//+------------------------------------------------------------------+
//|              Gold Sweep Reversal EA v2                           |
//|           Liquidity Sweep + BOS + Magic Number                   |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>

CTrade trade;

//=========================
// INPUT
//=========================

input int MagicNumber = 888002;

input double LotSize = 0.01;
input double RR = 2.0;

input int TradeStartHour = 14;
input int TradeEndHour = 23;

input int SwingLookback = 20;

input double SweepBuffer = 0.5;
input double BOSBuffer = 0.3;
input double SLBuffer = 1.0;

input int MaxTradesPerDay = 2;

//=========================

bool WaitingBOS = false;

string BOSDirection = "";

double SweepHigh = 0;
double SweepLow = 0;
double BOSLevel = 0;

int TradeCountToday = 0;
int LastDay = -1;

//+------------------------------------------------------------------+
//| INIT                                                             |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(MagicNumber);

   Print("Gold Sweep Reversal EA v2 Started");

   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| MAIN                                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   MqlDateTime tm;
   TimeToStruct(TimeCurrent(), tm);

   // Reset mỗi ngày
   if(tm.day != LastDay)
   {
      TradeCountToday = 0;
      LastDay = tm.day;

      WaitingBOS = false;
   }

   // Chỉ trade trong giờ
   if(tm.hour < TradeStartHour || tm.hour > TradeEndHour)
      return;

   // Giới hạn số lệnh/ngày
   if(TradeCountToday >= MaxTradesPerDay)
      return;

   // Chỉ check lệnh của bot này
   if(HasMyPosition())
      return;

   double lastClose = iClose(_Symbol, PERIOD_M5, 1);

   double lastHigh = iHigh(_Symbol, PERIOD_M5, 1);
   double lastLow = iLow(_Symbol, PERIOD_M5, 1);

   double prevHigh = iHigh(_Symbol, PERIOD_M5, 2);
   double prevLow = iLow(_Symbol, PERIOD_M5, 2);

   //=========================
   // TÌM SWEEP
   //=========================

   if(!WaitingBOS)
   {
      double swingHigh = GetSwingHigh();
      double swingLow = GetSwingLow();

      Print("Swing High: ", swingHigh);
      Print("Swing Low: ", swingLow);

      //=========================
      // SELL SWEEP
      //=========================

      if(lastHigh > swingHigh + SweepBuffer &&
         lastClose < swingHigh)
      {
         WaitingBOS = true;

         BOSDirection = "SELL";

         SweepHigh = lastHigh;
         SweepLow = lastLow;

         BOSLevel = prevLow;

         Print("Sweep SELL detected");
         Print("Waiting BOS SELL");
      }

      //=========================
      // BUY SWEEP
      //=========================

      if(lastLow < swingLow - SweepBuffer &&
         lastClose > swingLow)
      {
         WaitingBOS = true;

         BOSDirection = "BUY";

         SweepHigh = lastHigh;
         SweepLow = lastLow;

         BOSLevel = prevHigh;

         Print("Sweep BUY detected");
         Print("Waiting BOS BUY");
      }
   }

   //=========================
   // CHỜ BOS
   //=========================

   else
   {
      // SELL BOS
      if(BOSDirection == "SELL")
      {
         if(lastClose < BOSLevel - BOSBuffer)
         {
            Print("BOS SELL confirmed");

            OpenSell();

            WaitingBOS = false;
         }
      }

      // BUY BOS
      if(BOSDirection == "BUY")
      {
         if(lastClose > BOSLevel + BOSBuffer)
         {
            Print("BOS BUY confirmed");

            OpenBuy();

            WaitingBOS = false;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| CHECK POSITION                                                   |
//+------------------------------------------------------------------+
bool HasMyPosition()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);

      if(PositionSelectByTicket(ticket))
      {
         long magic = PositionGetInteger(POSITION_MAGIC);

         string symbol = PositionGetString(POSITION_SYMBOL);

         if(magic == MagicNumber &&
            symbol == _Symbol)
         {
            return true;
         }
      }
   }

   return false;
}

//+------------------------------------------------------------------+
//| SWING HIGH                                                       |
//+------------------------------------------------------------------+
double GetSwingHigh()
{
   double high = -999999;

   for(int i = 3; i < SwingLookback + 3; i++)
   {
      double h = iHigh(_Symbol, PERIOD_M5, i);

      if(h > high)
         high = h;
   }

   return high;
}

//+------------------------------------------------------------------+
//| SWING LOW                                                        |
//+------------------------------------------------------------------+
double GetSwingLow()
{
   double low = 999999;

   for(int i = 3; i < SwingLookback + 3; i++)
   {
      double l = iLow(_Symbol, PERIOD_M5, i);

      if(l < low)
         low = l;
   }

   return low;
}

//+------------------------------------------------------------------+
//| OPEN SELL                                                        |
//+------------------------------------------------------------------+
void OpenSell()
{
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   double sl = SweepHigh + SLBuffer;

   double risk = sl - bid;

   double tp = bid - (risk * RR);

   if(risk <= 0)
   {
      Print("SELL risk lỗi");
      return;
   }

   bool result = trade.Sell(
      LotSize,
      _Symbol,
      bid,
      sl,
      tp,
      "Sweep BOS SELL"
   );

   if(result)
   {
      TradeCountToday++;

      Print("SELL OPENED");
   }
   else
   {
      Print("SELL FAILED");
   }
}

//+------------------------------------------------------------------+
//| OPEN BUY                                                         |
//+------------------------------------------------------------------+
void OpenBuy()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   double sl = SweepLow - SLBuffer;

   double risk = ask - sl;

   double tp = ask + (risk * RR);

   if(risk <= 0)
   {
      Print("BUY risk lỗi");
      return;
   }

   bool result = trade.Buy(
      LotSize,
      _Symbol,
      ask,
      sl,
      tp,
      "Sweep BOS BUY"
   );

   if(result)
   {
      TradeCountToday++;

      Print("BUY OPENED");
   }
   else
   {
      Print("BUY FAILED");
   }
}
